{
  "name": "moonstride",
  "version": "0.1.0",
  "private": true,
  "description": "State-of-the-art MCP server + Next.js dashboard for the Moonstride CRM/booking API",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "mcp:stdio": "npm run -w @moonstride/mcp-server start:stdio",
    "mcp:http": "npm run -w @moonstride/mcp-server start:http",
    "dashboard:dev": "npm run -w @moonstride/dashboard dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
