# ── Moonstride API credentials ─────────────────────────────────────────────
# Base URL of the Moonstride API. Defaults to the public demo environment.
# For local dev point this at http://api-local.moonstride.local
MOONSTRIDE_BASE_URL=https://demo.moonstride.com

# Sent as the `x-api-key` header when generating a token.
# The public demo documentation key is shown below as a placeholder.
MOONSTRIDE_API_KEY=4b683bb6-fd95-46f2-afd2-d058fceb22de

# Sent as the `clientid` header when generating a token.
MOONSTRIDE_CLIENT_ID=

# Sent in the token-generation request body.
MOONSTRIDE_SECRET_KEY=
MOONSTRIDE_USER_ID=

# Optional: request timeout in milliseconds (default 30000).
MOONSTRIDE_TIMEOUT_MS=30000

# ── MCP HTTP transport ─────────────────────────────────────────────────────
# Port for the Streamable-HTTP MCP server (npm run mcp:http).
PORT=8787
# Optional: if set, /mcp requires `Authorization: Bearer <this>`. Leave empty
# to disable (only safe behind a private network / trusted gateway).
MCP_AUTH_TOKEN=

# ── Dashboard ──────────────────────────────────────────────────────────────
# (the Next.js app reads the MOONSTRIDE_* vars above, server-side only)

# Dashboard login. Auth is ENFORCED as soon as DASHBOARD_PASSWORD is set; if it
# is empty the dashboard runs open (local dev only). Protecting the dashboard
# also protects the /api/moonstride/* and /api/chat routes that use the
# server-side Moonstride credentials.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
# Secret used to sign the session cookie (use a long random string in prod).
# Falls back to DASHBOARD_PASSWORD if unset.
AUTH_SECRET=

# Embeddable chat widget: if set, /api/chat accepts requests carrying the
# matching `x-widget-key` header (used by /embed.js on external pages) without
# a dashboard session. Leave empty to keep the widget for logged-in users only.
WIDGET_KEY=

# ── AI Assistant (chat frontend) ───────────────────────────────────────────
# Required only for the /chat page. Get a key at https://platform.openai.com
OPENAI_API_KEY=
# Optional: override the model used by the assistant (must support tool calling).
OPENAI_MODEL=gpt-5.4-mini
# Optional: point at an OpenAI-compatible endpoint (Azure OpenAI, local, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1
